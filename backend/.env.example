# ==========================================================
# MANGALIK PLATFORM — ENVIRONMENT CONFIGURATION (TEMPLATE)
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ==========================================================

# ---------------- Server ----------------
NODE_ENV=development
PORT=5000
CLIENT_USER_URL=https://www.mangalik.store
CLIENT_DASHBOARD_URL=https://admin.mangalik.store
API_BASE_URL=https://api.mangalik.store
COOKIE_DOMAIN=.mangalik.store

# ---------------- MongoDB ----------------
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mangalik?retryWrites=true&w=majority
MONGO_URI_TEST=mongodb://127.0.0.1:27017/mangalik_test

# ---------------- JWT / Sessions ----------------
JWT_ACCESS_SECRET=replace_with_64_char_random_secret
JWT_REFRESH_SECRET=replace_with_different_64_char_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECRET=replace_with_random_secret

# ---------------- Bcrypt ----------------
BCRYPT_SALT_ROUNDS=12

# ---------------- Firebase Admin (Auth: Google / Email / Phone) ----------------
FIREBASE_PROJECT_ID=mangalik-platform
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@mangalik-platform.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------- Razorpay ----------------
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---------------- Google AdSense / Ads Manager ----------------
DEFAULT_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
DEFAULT_ADSENSE_ENABLED=true

# ---------------- Cloudinary (Media) ----------------
CLOUDINARY_CLOUD_NAME=mangalik
CLOUDINARY_API_KEY=xxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxx

# ---------------- Mail (Transactional) ----------------
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_USER=support@mangalik.store
SMTP_PASS=xxxxxxxx
MAIL_FROM="Mangalik <support@mangalik.store>"

# ---------------- Redis (Rate limiting / caching / sessions) ----------------
REDIS_URL=redis://localhost:6379

# ---------------- Security ----------------
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX_REQUESTS=300
LOGIN_RATE_LIMIT_MAX=8
ENCRYPTION_SECRET_KEY=replace_with_32_byte_secret_key_aes256
SUPERADMIN_MASTER_EMAIL=owner@adityatechndevoops.in
ALLOWED_ORIGINS=https://www.mangalik.store,https://admin.mangalik.store,http://localhost:3000,http://localhost:3001

# ---------------- Logging ----------------
LOG_LEVEL=info
